# For deployed preview (same-origin API calls), leave empty:
# EXPO_PUBLIC_API_URL=

# For local development (web browser only):
# EXPO_PUBLIC_API_URL=http://localhost:8001

# For device testing (Android/iPhone on same WiFi):
# Use your machine's LAN IP - find it with: hostname -I (Linux) / ipconfig (Win) / ifconfig (Mac)
EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:8001
